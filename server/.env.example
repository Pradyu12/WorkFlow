# Firebase Admin SDK service account key (JSON)
# Either set FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
# or set GOOGLE_APPLICATION_CREDENTIALS to the path of your service-account.json

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Or use a service account file:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

PORT=3001
CLIENT_URL=http://localhost:5173
